# Copy to /etc/systemd/system/meshnet.service and edit User, WorkingDirectory,
# ExecStart path, and config path for this Pi.
[Unit]
Description=MeshNet Meshtastic Runtime
Wants=network-online.target
After=network-online.target

[Service]
Type=simple
User=pi
WorkingDirectory=/home/pi/meshnet
Environment=PYTHONUNBUFFERED=1
ExecStart=/home/pi/meshnet/.venv/bin/python -m src.cli run --config /home/pi/meshnet/config.master.yaml
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
